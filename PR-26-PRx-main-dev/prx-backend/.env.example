# Copia este archivo a .env y rellénalo con tus valores locales.
# Nunca subas .env al repositorio (contiene secretos).

# =============================================
# BASE DE DATOS (MySQL)
# =============================================
DATABASE_URL="mysql://USUARIO:CONTRASEÑA@localhost:3306/nombre_base_datos"

# =============================================
# APLICACIÓN
# =============================================
APP_NAME="PRX Backend"
APP_VERSION="1.0.0"
PORT=3000
API_PREFIX="prx"

# =============================================
# JWT (genera cadenas largas aleatorias en producción)
# =============================================
JWT_ACCESS_SECRET="reemplazar_con_un_secreto_largo_para_acceso"
JWT_REFRESH_SECRET="reemplazar_con_un_secreto_largo_para_refresco"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =============================================
# CORREO
# =============================================
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="tu_correo@gmail.com"
MAIL_PASS="contraseña_de_aplicacion_o_app_password"
MAIL_FROM="PRX <tu_correo@gmail.com>"
# En local el backend suele loguear el código en consola (MailService).
# Para probar SMTP real con Gmail: MAIL_FORCE_SMTP=true (sin MAIL_SKIP_SEND si aplica).

# =============================================
# STORAGE TIGRIS (opcional)
# =============================================
TIGRIS_STORAGE_ACCESS_KEY_ID=""
TIGRIS_STORAGE_SECRET_ACCESS_KEY=""
TIGRIS_STORAGE_ENDPOINT=""
TIGRIS_PUBLIC_BUCKET=""
TIGRIS_PRIVATE_BUCKET=""

# =============================================
# THROTTLE
# =============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=20
